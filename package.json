{
  "name": "design-service-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:push": "prisma db push",
    "db:seed": "node scripts/seed-db.js",
    "db:studio": "prisma studio",
    "db:migrate:prod": "node scripts/migrate-prod.js",
    "db:backup:dev": "node scripts/backup-db.js dev",
    "db:backup:prod": "node scripts/backup-db.js prod",
    "db:validate": "node -e \"require('@prisma/client').PrismaClient()\"",
    "build:prod": "npm run build && npm run db:migrate:prod",
    "start:prod": "NODE_ENV=production next start",
    "deploy": "npm run build && npm run db:migrate:prod && npm run start:prod",
    "test": "echo \"Test suite not configured yet\"",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "diagnose": "npm run type-check && npm run lint"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "@stripe/react-stripe-js": "^6.6.0",
    "@stripe/stripe-js": "^9.7.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "jsonwebtoken": "^9.0.3",
    "next": "16.2.7",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "stripe": "^22.2.0",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-slot": "^1.2.5",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "better-sqlite3": "^12.10.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "lucide-react": "^1.17.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
